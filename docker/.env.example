# ─────────────────────────────────────────────────────────────────────────────
# Freelancer Platform — Environment Variables
# Copy this file to .env and fill in real values before running docker compose.
# ─────────────────────────────────────────────────────────────────────────────

# ── PostgreSQL ────────────────────────────────────────────────────────────────
POSTGRES_DB=freelancer_db
POSTGRES_USER=freelancer_user
POSTGRES_PASSWORD=freelancer_pass

# ── Redis ─────────────────────────────────────────────────────────────────────
REDIS_PASSWORD=redis_pass

# ── RabbitMQ ──────────────────────────────────────────────────────────────────
RABBITMQ_USER=freelancer_user
RABBITMQ_PASS=freelancer_pass

# ── JWT (minimum 32 characters / 256 bits for HMAC-SHA256) ───────────────────
JWT_SECRET=change-me-please-use-at-least-32-characters-for-hmac-sha256

# ── VNPay Sandbox ─────────────────────────────────────────────────────────────
# Register at: https://sandbox.vnpayment.vn/devreg
VNPAY_TMN_CODE=
VNPAY_HASH_SECRET=
VNPAY_PAY_URL=https://sandbox.vnpayment.vn/paymentv2/vpcpay.html
VNPAY_API_URL=https://sandbox.vnpayment.vn/merchant_webapi/api/transaction
VNPAY_RETURN_URL=http://localhost:8080/api/vnpay/return
VNPAY_FE_SUCCESS=http://localhost:4200/payment/success
VNPAY_FE_CANCEL=http://localhost:4200/payment/cancel
# Leave empty in sandbox (VNPay prod IPs: 113.52.xxx.xxx)
VNPAY_IPN_ALLOWED_IPS=

# ── File Upload ───────────────────────────────────────────────────────────────
UPLOAD_DIR=/app/uploads
UPLOAD_BASE_URL=http://localhost:8080/uploads

# ── CORS ──────────────────────────────────────────────────────────────────────
CORS_ORIGINS=http://localhost:4200
